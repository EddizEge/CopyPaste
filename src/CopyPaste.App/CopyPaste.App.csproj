<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>CopyPaste.App</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>Assets\CopyPaste.ico</ApplicationIcon>
    <Platforms>x64</Platforms>
    <RuntimeIdentifiers>win-x64</RuntimeIdentifiers>
    <UseWinUI>true</UseWinUI>
    <WindowsPackageType Condition="'$(BuildMsix)' != 'true'">None</WindowsPackageType>
    <EnableMsixTooling Condition="'$(BuildMsix)' == 'true'">true</EnableMsixTooling>
    <AppxPackageSigningEnabled Condition="'$(BuildMsix)' == 'true'">false</AppxPackageSigningEnabled>
    <AppxSymbolPackageEnabled Condition="'$(BuildMsix)' == 'true'">false</AppxSymbolPackageEnabled>
    <DebugType Condition="'$(BuildMsix)' == 'true'">none</DebugType>
    <DebugSymbols Condition="'$(BuildMsix)' == 'true'">false</DebugSymbols>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Version>1.7.0</Version>
    <AssemblyVersion>1.7.0.0</AssemblyVersion>
    <FileVersion>1.7.0.0</FileVersion>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.8.260508005" />
    <ProjectReference Include="..\CopyPaste.Core\CopyPaste.Core.csproj" />
    <ProjectReference Include="..\CopyPaste.ExplorerCommand\CopyPaste.ExplorerCommand.csproj"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="Assets\*.png" />
    <Content Include="..\CopyPaste.ExplorerCommand\bin\$(Platform)\$(Configuration)\net8.0-windows10.0.19041.0\CopyPaste.ExplorerCommand.dll"
             Link="CopyPaste.ExplorerCommand.dll" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\CopyPaste.ExplorerCommand\bin\$(Platform)\$(Configuration)\net8.0-windows10.0.19041.0\CopyPaste.ExplorerCommand.deps.json"
             Link="CopyPaste.ExplorerCommand.deps.json" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\CopyPaste.ExplorerCommand\bin\$(Platform)\$(Configuration)\net8.0-windows10.0.19041.0\CopyPaste.ExplorerCommand.runtimeconfig.json"
             Link="CopyPaste.ExplorerCommand.runtimeconfig.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
